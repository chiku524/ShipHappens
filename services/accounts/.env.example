# Copy to .env and adjust. Never commit .env.
POSTGRES_USER=pudgymon
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=pudgymon_accounts
JWT_SECRET=change-me-long-random-hex
# Encrypts custodial Boing wallet secrets (defaults to JWT_SECRET if unset)
WALLET_MASTER_KEY=change-me-separate-from-jwt-ideal
# Host ports (container still uses 5432 / 8787 internally)
POSTGRES_HOST_PORT=5434
API_HOST_PORT=8788
