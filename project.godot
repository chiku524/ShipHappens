; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ShipHappens"
config/description="6-8 player cartoon space freight co-op with social deduction."
run/main_scene="res://scenes/main/main_menu.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

NetworkManager="*res://scripts/autoload/network_manager.gd"
GameState="*res://scripts/autoload/game_state.gd"
JobSystem="*res://scripts/autoload/job_system.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

